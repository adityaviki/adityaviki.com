---
interface Props {
  chart: string;
}

const { chart } = Astro.props;
---

<div class="mermaid-wrapper my-8">
  <pre class="mermaid">{chart}</pre>
</div>

<script>
  async function renderMermaid() {
    const mermaid = (await import('https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.esm.min.mjs')).default;
    const isDark = document.documentElement.classList.contains('dark');
    mermaid.initialize({
      startOnLoad: false,
      theme: isDark ? 'dark' : 'default',
      themeVariables: isDark
        ? { primaryColor: '#2a2118', primaryTextColor: '#e8e6e3', lineColor: '#d4976a', secondaryColor: '#1e1e1e' }
        : { primaryColor: '#f5ebe3', primaryTextColor: '#1a1a1a', lineColor: '#c9885c', secondaryColor: '#f3f2f0' },
    });
    await mermaid.run({ querySelector: '.mermaid' });
  }
  renderMermaid();
  document.addEventListener('astro:after-swap', renderMermaid);
</script>

---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map(project => ({
    params: { id: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
---

<Base title={project.data.title} description={project.data.description}>
  <article class="animate-in">
    <header class="mb-10">
      <a
        href="/projects"
        class="inline-flex items-center gap-1 text-xs text-[var(--color-text-tertiary)] hover:text-[var(--color-accent)] transition-colors duration-200 mb-6"
      >
        <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path d="M19 12H5M12 19l-7-7 7-7" />
        </svg>
        Projects
      </a>
      <h1 class="text-2xl sm:text-3xl font-semibold tracking-tight leading-tight mb-3" style="font-family: var(--font-serif); letter-spacing: -0.02em;">
        {project.data.title}
      </h1>
      <p class="text-[var(--color-text-secondary)] leading-relaxed mb-4">{project.data.description}</p>
      <div class="flex flex-wrap items-center gap-3">
        {project.data.tags.map(tag => (
          <span class="text-xs text-[var(--color-text-tertiary)] bg-[var(--color-bg-secondary)] px-2.5 py-1 rounded-full border border-[var(--color-border)]">
            {tag}
          </span>
        ))}
        {project.data.github && (
          <a
            href={project.data.github}
            class="inline-flex items-center gap-1.5 text-xs text-[var(--color-text-secondary)] hover:text-[var(--color-accent)] transition-colors duration-200"
            target="_blank"
            rel="noopener noreferrer"
          >
            <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
            </svg>
            Source
          </a>
        )}
        {project.data.url && (
          <a
            href={project.data.url}
            class="inline-flex items-center gap-1.5 text-xs text-[var(--color-text-secondary)] hover:text-[var(--color-accent)] transition-colors duration-200"
            target="_blank"
            rel="noopener noreferrer"
          >
            <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6M15 3h6v6M10 14L21 3" />
            </svg>
            Live site
          </a>
        )}
      </div>
    </header>

    <div class="prose animate-in animate-in-delay-1">
      <Content />
    </div>
  </article>

  <div class="mt-20 pt-6 border-t border-[var(--color-border)]">
    <a
      href="/projects"
      class="inline-flex items-center gap-1.5 text-sm text-[var(--color-text-secondary)] hover:text-[var(--color-accent)] transition-colors duration-200"
    >
      <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path d="M19 12H5M12 19l-7-7 7-7" />
      </svg>
      All projects
    </a>
  </div>
</Base>

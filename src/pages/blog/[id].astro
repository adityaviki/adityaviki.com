---
import Base from '../../layouts/Base.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { id: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const wordCount = post.body ? post.body.split(/\s+/).length : 0;
const readTime = Math.max(1, Math.ceil(wordCount / 200));
---

<Base title={post.data.title} description={post.data.description}>
  <article class="animate-in">
    <header class="mb-10">
      <a
        href="/blog"
        class="inline-flex items-center gap-1 text-xs text-[var(--color-text-tertiary)] hover:text-[var(--color-accent)] transition-colors duration-200 mb-6"
      >
        <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path d="M19 12H5M12 19l-7-7 7-7" />
        </svg>
        Writing
      </a>
      <h1 class="text-2xl sm:text-3xl font-semibold tracking-tight leading-tight mb-4" style="font-family: var(--font-serif); letter-spacing: -0.02em;">
        {post.data.title}
      </h1>
      <div class="flex items-center gap-2 text-xs text-[var(--color-text-tertiary)]">
        <FormattedDate date={post.data.date} />
        <span class="text-[var(--color-border)]">/</span>
        <span>{readTime} min read</span>
      </div>
      {post.data.tags.length > 0 && (
        <div class="flex gap-2 mt-4">
          {post.data.tags.map(tag => (
            <span class="text-xs text-[var(--color-text-tertiary)] bg-[var(--color-bg-secondary)] px-2.5 py-1 rounded-full border border-[var(--color-border)]">
              {tag}
            </span>
          ))}
        </div>
      )}
    </header>

    <div class="prose animate-in animate-in-delay-1">
      <Content />
    </div>
  </article>

  <div class="mt-20 pt-6 border-t border-[var(--color-border)]">
    <a
      href="/blog"
      class="inline-flex items-center gap-1.5 text-sm text-[var(--color-text-secondary)] hover:text-[var(--color-accent)] transition-colors duration-200"
    >
      <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path d="M19 12H5M12 19l-7-7 7-7" />
      </svg>
      All posts
    </a>
  </div>
</Base>

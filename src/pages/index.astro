---
import Base from '../layouts/Base.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const projects = (await getCollection('projects'))
  .filter(p => p.data.featured);

const postsByYear = posts.reduce((acc, post) => {
  const year = post.data.date.getFullYear();
  if (!acc[year]) acc[year] = [];
  acc[year].push(post);
  return acc;
}, {} as Record<number, typeof posts>);

const years = Object.keys(postsByYear).map(Number).sort((a, b) => b - a);
---

<Base>
  <!-- Intro -->
  <section class="mb-20 animate-in">
    <h1 class="text-2xl sm:text-3xl font-serif font-semibold tracking-tight leading-snug mb-4" style="font-family: var(--font-serif); letter-spacing: -0.02em;">
      I build software and<br class="hidden sm:block" /> write about it here.
    </h1>
    <p class="text-[var(--color-text-secondary)] leading-relaxed max-w-md">
      Software developer. Thinking about design, simplicity, and the tools we use to create.
    </p>
  </section>

  <!-- Featured Projects -->
  {projects.length > 0 && (
    <section class="mb-20 animate-in animate-in-delay-1">
      <div class="flex items-center gap-3 mb-8">
        <h2 class="text-xs font-medium text-[var(--color-text-tertiary)] uppercase tracking-[0.15em]">Projects</h2>
        <div class="flex-1 h-px bg-[var(--color-border)]"></div>
      </div>
      <div class="space-y-3">
        {projects.map(project => (
          <a
            href={project.data.url || project.data.github || `/projects/${project.id}`}
            class="group block p-4 -mx-4 rounded-lg hover:bg-[var(--color-bg-secondary)] transition-all duration-200"
            target={project.data.url ? '_blank' : undefined}
            rel={project.data.url ? 'noopener noreferrer' : undefined}
          >
            <div class="flex items-start justify-between gap-4">
              <div>
                <span class="font-medium text-[var(--color-text)] group-hover:text-[var(--color-accent)] transition-colors duration-200">
                  {project.data.title}
                </span>
                <p class="text-sm text-[var(--color-text-secondary)] mt-1">{project.data.description}</p>
              </div>
              <span class="text-[var(--color-text-tertiary)] group-hover:text-[var(--color-accent)] group-hover:translate-x-0.5 transition-all duration-200 mt-0.5 shrink-0">&rarr;</span>
            </div>
          </a>
        ))}
      </div>
      <a href="/projects" class="inline-block mt-4 text-sm text-[var(--color-text-tertiary)] hover:text-[var(--color-accent)] link-hover transition-colors duration-200">
        View all projects
      </a>
    </section>
  )}

  <!-- Writing -->
  <section class="animate-in animate-in-delay-2">
    <div class="flex items-center gap-3 mb-8">
      <h2 class="text-xs font-medium text-[var(--color-text-tertiary)] uppercase tracking-[0.15em]">Writing</h2>
      <div class="flex-1 h-px bg-[var(--color-border)]"></div>
    </div>
    {years.map(year => (
      <div class="mb-10">
        <h3 class="text-xs font-medium text-[var(--color-text-tertiary)] mb-5 tabular-nums">{year}</h3>
        <div class="space-y-2">
          {postsByYear[year].map(post => (
            <a href={`/blog/${post.id}`} class="group flex items-baseline py-1.5">
              <span class="text-[var(--color-text)] group-hover:text-[var(--color-accent)] transition-colors duration-200">
                {post.data.title}
              </span>
              <span class="dot-leader"></span>
              <span class="text-xs text-[var(--color-text-tertiary)] shrink-0 tabular-nums">
                <FormattedDate date={post.data.date} />
              </span>
            </a>
          ))}
        </div>
      </div>
    ))}
  </section>
</Base>
